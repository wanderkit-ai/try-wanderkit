datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─── CREATORS ────────────────────────────────────────────────────────────────

model Creator {
  id              String        @id @default(cuid())
  userId          String        @unique
  slug            String        @unique
  name            String
  handle          String
  bio             String?       @db.Text
  photoUrl        String?
  followerCount   Int?
  primaryPlatform String?
  websiteUrl      String?
  email           String

  stripeConnectId String?
  payoutEmail     String?

  status     CreatorStatus @default(PENDING)
  approvedAt DateTime?

  drops Drop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CreatorStatus {
  PENDING
  APPROVED
  SUSPENDED
}

// ─── OPERATORS ───────────────────────────────────────────────────────────────

model Operator {
  id           String  @id @default(cuid())
  name         String
  region       String
  country      String
  description  String? @db.Text
  license      String?
  yearsActive  Int?
  contactName  String?
  contactEmail String?
  contactPhone String?
  websiteUrl   String?
  logoUrl      String?
  verified     Boolean @default(false)

  drops Drop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── DROPS ───────────────────────────────────────────────────────────────────

model Drop {
  id         String @id @default(cuid())
  dropNumber Int    @unique @default(autoincrement())
  slug       String @unique

  creatorId  String
  creator    Creator   @relation(fields: [creatorId], references: [id])
  operatorId String?
  operator   Operator? @relation(fields: [operatorId], references: [id])

  title       String
  subtitle    String?
  description String  @db.Text
  creatorNote String? @db.Text
  destination String
  country     String
  heroImageUrl  String?
  galleryImages String[]

  departureDate       DateTime
  returnDate          DateTime
  applicationDeadline DateTime

  totalSpots       Int       @default(12)
  pricePerPerson   Int
  depositAmount    Int
  depositDeadline  DateTime?
  singleSupplement Int?

  itinerary Json
  included  Json
  excluded  String[]
  faqs      Json

  stripeProductId      String?
  stripeDepositPriceId String?
  stripeFullPriceId    String?

  status      DropStatus @default(DRAFT)
  publishedAt DateTime?

  applications Application[]

  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DropStatus {
  DRAFT
  REVIEW
  LIVE
  CLOSED
  COMPLETED
  CANCELLED
}

// ─── APPLICATIONS ────────────────────────────────────────────────────────────

model Application {
  id     String @id @default(cuid())
  dropId String
  drop   Drop   @relation(fields: [dropId], references: [id])

  firstName       String
  lastName        String
  email           String
  phone           String?
  instagramHandle String?
  nationality     String?
  passportCountry String?

  roomPreference RoomPreference @default(TWIN_SHARE)
  dietaryNeeds   String?
  medicalNotes   String?
  emergencyName  String?
  emergencyPhone String?

  motivation String  @db.Text
  heardAbout String?

  status     ApplicationStatus @default(SUBMITTED)
  reviewedAt DateTime?
  reviewNote String?

  depositPaid           Boolean   @default(false)
  depositAmount         Int?
  depositPaidAt         DateTime?
  stripeSessionId       String?
  stripePaymentIntentId String?

  fullPaymentPaid   Boolean   @default(false)
  fullPaymentPaidAt DateTime?

  confirmationSentAt DateTime?
  reminderSentAt     DateTime?
  prepPackSentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dropId, email])
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DEPOSIT_PAID
  WAITLISTED
  REJECTED
  WITHDRAWN
  COMPLETED
}

enum RoomPreference {
  TWIN_SHARE
  SINGLE_SUPPLEMENT
}

// ─── ITINERARY GENERATION LOG ────────────────────────────────────────────────

model ItineraryGenerationLog {
  id         String   @id @default(cuid())
  dropId     String?
  creatorId  String?
  prompt     String   @db.Text
  response   String   @db.Text
  tokensUsed Int?
  createdAt  DateTime @default(now())
}

// ─── WAITLIST ────────────────────────────────────────────────────────────────

model Waitlist {
  id        String   @id @default(cuid())
  dropId    String
  email     String
  name      String?
  createdAt DateTime @default(now())

  @@unique([dropId, email])
}
